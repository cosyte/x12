{
  "name": "@cosyte/x12",
  "version": "0.0.0",
  "description": "Developer-focused ASC X12 EDI parser and utility library for Node.js/TypeScript.",
  "license": "MIT",
  "author": "Cosyte",
  "repository": {
    "type": "git",
    "url": "https://github.com/cosyte/x12"
  },
  "homepage": "https://github.com/cosyte/x12#readme",
  "bugs": {
    "url": "https://github.com/cosyte/x12/issues"
  },
  "keywords": [
    "x12",
    "edi",
    "healthcare",
    "hipaa",
    "835",
    "837",
    "271",
    "parser",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.4",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "prebuild": "pnpm run clean",
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:exports": "node scripts/verify-exports.mjs && node scripts/verify-exports.cjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "20.19.41",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3"
  }
}
