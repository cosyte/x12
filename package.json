{
  "name": "@cosyte/x12",
  "version": "0.0.0",
  "description": "Developer-focused ASC X12 EDI parser and utility library for Node.js/TypeScript.",
  "license": "MIT",
  "author": "Cosyte",
  "repository": {
    "type": "git",
    "url": "https://github.com/cosyte/x12"
  },
  "homepage": "https://github.com/cosyte/x12#readme",
  "bugs": {
    "url": "https://github.com/cosyte/x12/issues"
  },
  "keywords": [
    "x12",
    "edi",
    "healthcare",
    "hipaa",
    "835",
    "837",
    "271",
    "parser",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "prettier": "@cosyte/prettier-config",
  "scripts": {
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "prebuild": "pnpm run clean",
    "build": "tsup",
    "changeset": "changeset",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,md}\" \"test/**/*.ts\" \"*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,md}\" \"test/**/*.ts\" \"*.{json,md,yml,yaml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify:exports": "node scripts/verify-exports.mjs && node scripts/verify-exports.cjs",
    "pack:docs": "bash scripts/build-docs-artifacts.sh",
    "release": "changeset publish"
  },
  "dependencies": {},
  "pnpm": {
    "overrides": {
      "vite": "^6.4.2",
      "eslint-visitor-keys": "^4.2.1"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@cosyte/eslint-config": "^0.0.2",
    "@cosyte/prettier-config": "^0.0.1",
    "@cosyte/tsconfig": "^0.0.1",
    "@types/node": "20.19.41",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
