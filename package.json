{
  "name": "@cosyte/x12",
  "version": "0.0.0",
  "description": "Developer-focused ASC X12 EDI parser and utility library for Node.js/TypeScript.",
  "license": "MIT",
  "author": "Cosyte <hello@cosyte.com> (https://cosyte.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosyte/x12.git"
  },
  "homepage": "https://github.com/cosyte/x12#readme",
  "bugs": {
    "url": "https://github.com/cosyte/x12/issues"
  },
  "keywords": [
    "x12",
    "edi",
    "healthcare",
    "hipaa",
    "835",
    "837",
    "271",
    "parser",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prettier": "@cosyte/prettier-config",
  "scripts": {
    "build": "tsup",
    "changeset": "changeset",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,md}\" \"test/**/*.ts\" \"*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,md}\" \"test/**/*.ts\" \"*.{json,md,yml,yaml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "verify:exports": "node scripts/verify-exports.mjs && node scripts/verify-exports.cjs",
    "pack:docs": "bash scripts/build-docs-artifacts.sh",
    "attw": "attw --pack .",
    "release": "changeset publish",
    "prepublishOnly": "pnpm clean && pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm attw"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@changesets/cli": "2.31.0",
    "@cosyte/eslint-config": "^0.0.3",
    "@cosyte/prettier-config": "^0.0.2",
    "@cosyte/tsconfig": "^0.0.2",
    "@cosyte/tsup-config": "^0.0.1",
    "@cosyte/vitest-config": "^0.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.5.0",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.4"
  },
  "dependencies": {}
}
