{
  "name": "@cosyte/x12",
  "version": "0.0.0",
  "description": "Developer-focused ASC X12 EDI parser and utility library for Node.js/TypeScript.",
  "license": "MIT",
  "author": "Cosyte <hello@cosyte.com> (https://cosyte.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosyte/x12.git"
  },
  "homepage": "https://github.com/cosyte/x12#readme",
  "bugs": {
    "url": "https://github.com/cosyte/x12/issues"
  },
  "keywords": [
    "x12",
    "edi",
    "healthcare",
    "hipaa",
    "835",
    "837",
    "271",
    "parser",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prettier": "@cosyte/prettier-config",
  "scripts": {
    "build": "tsup",
    "changeset": "changeset",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\" --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.{ts,md}\" \"scripts/**/*.ts\" \"test/**/*.ts\" \"*.{json,md,yml,yaml}\" --no-error-on-unmatched-pattern",
    "format:check": "prettier --check \"src/**/*.{ts,md}\" \"scripts/**/*.ts\" \"test/**/*.ts\" \"*.{json,md,yml,yaml}\" --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "phi-scan": "tsx scripts/phi-scan.ts",
    "refresh:code-lists": "tsx scripts/refresh-code-lists.ts",
    "verify:exports": "node scripts/verify-exports.mjs && node scripts/verify-exports.cjs",
    "pack:docs": "bash scripts/build-docs-artifacts.sh",
    "attw": "attw --pack .",
    "version": "changeset version && node scripts/sync-version.mjs && prettier --write package.json src/index.ts",
    "release": "changeset publish",
    "prepublishOnly": "pnpm clean && pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm attw",
    "prepare": "command -v simple-git-hooks >/dev/null 2>&1 && simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm phi-scan --staged"
  },
  "pnpm": {
    "overrides": {
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "js-yaml@>=4.0.0 <4.2.0": "4.2.0"
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@changesets/cli": "2.31.0",
    "@cosyte/eslint-config": "^0.0.4",
    "@cosyte/prettier-config": "^0.0.2",
    "@cosyte/test-utils": "^0.0.1",
    "@cosyte/tsconfig": "^0.0.2",
    "@cosyte/tsup-config": "^0.0.1",
    "@cosyte/vitest-config": "^0.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "fast-check": "4.9.0",
    "prettier": "3.9.5",
    "simple-git-hooks": "2.13.1",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "dependencies": {}
}
